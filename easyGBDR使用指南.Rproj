# Other Function Introductions
## Quantile()
Can divide into multiple quantiles based on maximum and minimum values
```{r eval=FALSE}
# Data reading
GBD <- read.csv("E:/clinical data mining/Xiaoming/plot/worldmap/national HIV.csv")
## Data filtering
GBD <- GBD %>% filter(sex=='Both' & year == 2019 & measure == 'Incidence')
## Convert the variable to N quantiles through the Quantile function
GBD$val2 <- Quantile(GBD$val,n=5)
    plot <- ggGBDmap(GBD,variable = 'val2',color = 'scale_fill_jco() + scale_color_jco()',
                     guide_name = 'ASR')
```

The figure below shows the running results. The generated variable val2 will automatically be converted to a categorical variable and automatically matched with labels
![](D:/BaiduSyncdisk/2.课题/easy GBDR写作/easyGBDRdocument/quntile.png)

## ggGBDmap()
Automatically creates beautiful world map layouts based on results from 204 countries
```{r eval=FALSE}
# World map plotting
plot <- ggGBDmap(GBD,variable = 'val2',color = 'scale_fill_jco() + scale_color_jco()',
                     guide_name = 'ASR')
```


The figure below shows the results of running ggGBDmap(): generates a beautiful world map without Chinese border issues
![](D:/BaiduSyncdisk/2.课题/easy GBDR写作/easyGBDRdocument/ggGBDmap.png)

## GBD_factor Function
This function can automatically convert categorical variables in GBD data into ordered categorical variables
```{r eval=FALSE}
#  GBD_factor
## Convert variables in GBD data to ordered factors,
## If you don't want to convert a variable, choose NULL (default variable, if not selected, you can directly delete this paragraph,
## For example, rei_order=NULL below can be directly deleted), GBD database default order selects TRUE, custom order, input vector can be, such as c("Deaths", "DALYs (Disability-Adjusted Life Years)","Prevalence", "Incidence")
data <- read.csv('EC_predict.csv')
data <- GBD_factor(data,measure_order=T,cause_order=T,
                       sex_order=T,age_order=T,rei_order=NULL)
str(data)
```

The figure below shows the results of running GBD_factor(): you can see that the above results are all converted to ordered categorical variables
![](D:/BaiduSyncdisk/2.课题/easy GBDR写作/easyGBDRdocument/GBD factor.png)


## ggpyramid Function
This function can draw male-female pyramid graphs
```{r eval=FALSE}
## Custom x-axis: select the variable to use as the x-axis
## Custom group: select the variable for stacked graphs
## metric
data <- read.csv('EC_predict.csv')
data <- GBD_factor(data,measure_order=T,cause_order=T,
                       sex_order=T,age_order=T,rei_order=NULL)

 ggpyramid(data,group='cause',x_axis='age',metric='Number',percent=F)
```


## ggDx Function
This function can draw dual coordinate axis graphs of disease rates and disease numbers
```{r eval=FALSE}
#data	 GBD data
# x_axis	 x-axis variable, select from c("age","year")
# ratio	 Ratio of dual coordinate axes, you can choose "auto" for automatic calculation, or fill in a number
# group	 Grouping variable
#ASR	 Whether to select ASR for rate
case <- read.csv('nation.csv')
case_trend <- subset(case,
                         measure== 'Incidence' &
                           metric != 'Percent' &
                           year==2019 &
                           age != 'Age-standardized' &
                           age != 'All ages')

case_trend <- GBD_factor(case_trend)
ggDx(case_trend,x_axis='age',ratio='auto') +
      facet_grid(.~location)
```

The figure below shows the results of running ggDx(): x-axis is age, y-axis is dual coordinate axes for disease numbers and rates
![](D:/BaiduSyncdisk/2.课题/easy GBDR写作/easyGBDRdocument/ggDx.png)

## ggGBDsdiASR Function
This function can draw dual coordinate axis graphs of disease rates and disease numbers
```{r eval=FALSE}
#  GBD_factor
#data	 GBD data
# x_axis	 x-axis variable, select from c("age","year")
# ratio	 Ratio of dual coordinate axes, you can choose "auto" for automatic calculation, or fill in a number
# group	 Grouping variable
#ASR	 Whether to select ASR for rate
data <- read.csv('EC_nation.csv',header = T)
data <- subset(data, age=='Age-standardized' &
                   metric== 'Rate' &
                   measure=='Incidence')
EC <- GBD_factor(EC)
ggGBDsdiASR(data=EC,span_val=0.5,se_plot=F,cor='pearson')
```


\newpage 
# How to Use easyGBDR for GBD Data Analysis of Specific Age Groups
   Currently, many of our students have published first-tier SCI papers on specific age group analyses. The functions here basically all support specific age group analysis. Today we use CKD disease as an example to calculate and analyze results for the specific age group of 40-64 years.

## Download Required Data from Official Website
   We select CKD disease, select all data for ages 0-95, and select all indicators for download
![](D:/BaiduSyncdisk/2.课题/easy GBDR写作/easyGBDRdocument/GBD选择界面.png)


## Data Download
```{r eval=FALSE}
# Data download
download_GBD(url = 'https://vizhub.healthdata.org/gbd-results/result/e2910f32a73676a795f01856ad6f8c91',
             dest = getwd())
```

## Data Reading and Standardization Conversion
```{r}
# Data reading and conversion
data <- GBDread('IHME-GBD_2019_DATA-e2910f32-1.zip')
```


## Partial Data Display
```{r}
# Select the required data
temp <- data  %>%  
  filter(metric=="Number")  %>%  #Select Number
  filter(age %in% c("40 to 44","45 to 49","50 to 54"))  %>%  #Reverse selection, remove
  filter(location%in%c("China")) #Select region
colnames(temp)

# View data
unique_variable <- list(measure=unique(temp$measure),
                        location=unique(temp$location),
                        sex=unique(temp$sex),
                        age=unique(temp$age),
                        cause=unique(temp$cause),
                        metric=unique(temp$metric),
                        year=unique(temp$year))
unique_variable
```
## Calculate ASR, Crude Rate, and Disease Number for Ages 40-64
```{r}
# 1. Data reading and conversion
data_sub <- GBDage_recal(data,startage = 40,endage = 60, CI = T)
head(data_sub)
unique(data_sub$age)
unique(data_sub$metric)
```
## Calculate EAPC for ASR and Crude Rate
```{r}
# EAPC calculation
res_eapc <- GBDeapc(data = data_sub, rei = F, EAPC_95CI = TRUE, digits = 2, sep = " to ")
head(res_eapc)
```

## Calculate AAPC for ASR and Crude Rate
```{r}
# AAPC calculation
res_ASR_aapc <- GBDASR_aapc(
  data = data_sub,
  model = "ln",
  joinpoints = 3,
  rei_included = F,
  CI = TRUE,
  digits = 2,
  sep = " to ",
  constant_variance = T
)

res_age_aapc <- GBDage_aapc(
  data = data_sub,
  model = "ln",
  joinpoints = 3,
  rei_included = F,
  CI = TRUE,
  digits = 2,
  sep = " to ",
  constant_variance = T
)
res_ASR_aapc[["AAPC"]]
```


```{r}
# AAPC calculation
head(res_ASR_aapc[["AAPC"]])
head(res_age_aapc[["AAPC"]])
```

## APC Web Version Operation
```{r}
# APC web version operation
# Filter specific age groups
data_age <- subset(data, age %in% c('40 to 44','45 to 49','50 to 54','55 to 59','60 to 64'))

data_apc_web <- GBDapc_web(
  data = data_age,
  startyear = 1990,
  reference_age = 40, ## 50-54 as reference line
  reference_year = 1990,
  measure_name = unique(data_age$measure),
  cause_name = unique(data_age$cause),
  sex_name = unique(data_age$sex),
  location_name = unique(data_age$location),
  rei_name = NULL
)
```
```{r}
# APC web version result partial plotting
ggdrift(
  data = data_apc_web,
  CI = T,
  group_name = "sex",
  line_size = 1,
  measure_name = "Incidence",
  cause_name = "Chronic kidney disease",
  sex_name = c('Male','Female','Both'),
  location_name = c('China',"Democratic People's Republic of Korea"),
  rei_name = NULL
) + facet_grid(.~location)

```

## APC_IE Operation
```{r}
# APC-IE operation
data_apc_ie <- GBDapc_ie(
  data = data,
  startyear = 1990,
  startage = 40,
  endage = 60,
  measure_name = 'Incidence',
  cause_name = "Chronic kidney disease",
  sex_name = c('Male','Female','Both'),
  location_name = 'China',
  rei_name = NULL
)
```

```{r}
# APC-IE result partial display
head(data_apc_ie[["APC"]])
```


## GBD Prediction Models
```{r}
# NORPRED prediction
# Filter specific age groups
data_age <- subset(data, age %in% c('40 to 44','45 to 49','50 to 54','55 to 59','60 to 64'))
# Model running
data_nopred <- GBDnorpred_prediction(
  data = data_age,
  measure_name= 'Deaths',
  cause_name = "Chronic kidney disease",
  location_name = 'China',
  rei_name = NULL,
  By_sex = F,
  predyear = 2044,
  full_age_adjusted = F ## full_age_adjusted must be set to F
)
# Result partial plotting
ggprediction_Dx(
  data = data_nopred,
  ratio = 'auto',
  CI = F,
  predict_start = 2020,
  group_name = "sex",
  location_name = "China",
  measure_name = "Deaths",
  cause_name = "Chronic kidney disease",
  rei_name = NULL,
  sex_name = c('Male','Female','Both')
)

```


```{r}
# BAPC prediction
# Filter specific age groups
data_age <- subset(data, age %in% c('40 to 44','45 to 49','50 to 54','55 to 59','60 to 64'))
# Model running
data_bapc <- GBDbapc_prediction(
  data = data_age,
  measure_name= 'Deaths',
  cause_name = "Chronic kidney disease",
  location_name = 'China',
  rei_name = NULL,
  By_sex = T, ## Here we choose T, both prediction is based on separate predictions for male and female and then added together
  predyear = 2044,
  full_age_adjusted = F, ## full_age_adjusted must be set to F
  rate_lessen = NULL
)
# Result partial plotting
ggprediction_Dx(
  data = data_bapc,
  ratio = 'auto',
  CI = F,
  predict_start = 2020,
  group_name = "sex",
  location_name = "China",
  measure_name = "Deaths",
  cause_name = "Chronic kidney disease",
  rei_name = NULL,
  sex_name = c('Male','Female','Both')
)

```

## GBD Decomposition Analysis
```{r}
# Decomposition three-factor analysis
data_decomposition <- GBDdecomposition(
  data,
  byear = 1990,
  compareyear = 2019,
  startage = 40, ##Select corresponding age group for specific age group
  endage = 60,  ##Select corresponding age group for specific age group
  percent = "byear"
)
# Result partial plotting
ggdecomposition(
  data = data_decomposition,
  measure_name = "Incidence",
  location_name = unique(data$location),
  sex_name = c('Male','Female','Both'),
  rei_name = NULL,
  cause_name = "Chronic kidney disease",
  percent = T ##Plot change percentage
) + facet_grid(.~sex)

```



```{r}
# Decomposition four-factor analysis
data_decomposition_servity <- GBDdecomposition_servity(
  data,
  byear = 1990,
  compareyear = 2019,
  measure_name = c('DALYs (Disability-Adjusted Life Years)',"YLDs (Years Lived with Disability)","YLLs (Years of Life Lost)","Deaths"),
  startage = 40, ##Select corresponding age group for specific age group
  endage = 60,  ##Select corresponding age group for specific age group
  percent = "byear"
)
# Result partial plotting
ggdecomposition(
  data = data_decomposition_servity,
  measure_name = "Deaths",
  location_name = unique(data$location),
  sex_name = c('Male','Female','Both'),
  rei_name = NULL,
  cause_name = "Chronic kidney disease",
  percent = T ##Plot change percentage
) + facet_grid(.~sex)

```

```{r}
# Decomposition N-factor analysis
data_decomposition_subcategory <- GBDdecomposition_subcategory(
  data,
  byear = 1990,
  compareyear = 2019,
  subcategory = unique(data$cause), #Note the order
  startage = 40, ##Select corresponding age group for specific age group
  endage = 60,  ##Select corresponding age group for specific age group
  percent = "byear"
)
# Result partial plotting
ggdecomposition(
  data = data_decomposition_subcategory,
  measure_name = "Deaths",
  location_name = "China",
  sex_name = c('Male','Female','Both'),
  rei_name = NULL,
  cause_name = "Chronic kidney disease",
  percent = F ##Plot change percentage
) + facet_grid(.~sex)

```


## Inequality Analysis
```{r eval=FALSE}
# Using results after GBDage_recal: but requires 204 countries, we will not demonstrate here
data_slope <- GBDslope_index(
  data = data_sub,
  all_age_range = c(40,60), ##This is the parameter for specific age group analysis
  SDI = T,
  GBDregion = T,
  SuperGBDregion = T
)

data_concentration <- GBDconcentration_index(
  data = data_sub,
  all_age_range = c(40,60), ##This is the parameter for specific age group analysis
  SDI = T,
  GBDregion = T,
  SuperGBDregion = T
)
```

## Frontier Analysis
```{r eval=FALSE}
# Using results after GBDage_recal: but requires 204 countries, we will not demonstrate here
data_frontier <- GBDfrontier(
  data = data_sub,
  sex_name = "Both",
  cause_name = "Chronic kidney disease",
  measure_name = "Deaths",
  rei_name = NULL,
  age_name = "Age-stanardized",
  boot = 100,
  parallel = T
) 
```

## Calculate QCI
```{r eval=FALSE}
# Using results after GBDage_recal: but requires 204 countries, we will not demonstrate here
data_qci <- GBDqci_cal(data_sub)
```
